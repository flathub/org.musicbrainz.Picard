{
    "id": "org.musicbrainz.Picard",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.7",
    "sdk": "org.kde.Sdk",
    "command": "picard",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--device=all",
        "--filesystem=home",
        "--filesystem=xdg-music",
        "--filesystem=/tmp"
    ],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "version": "23.08",
            "add-ld-path": "."
        }
    },
    "cleanup-commands": [
        "mkdir -p /app/lib/ffmpeg"
    ],
    "build-options": {
        "env": {
            "PIP_DISABLE_PIP_VERSION_CHECK": "1"
        }
    },
    "modules": [
        "files/python3-build-deps.json",
        {
            "name": "pyqt-sip",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-build-isolation --verbose --prefix=${FLATPAK_DEST} ."
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.pythonhosted.org/packages/98/23/e54e02a44afc357ccab1b88575b90729664164358ceffde43e4f2e549daa/PyQt6_sip-13.6.0.tar.gz",
                    "sha256": "2486e1588071943d4f6657ba09096dc9fffd2322ad2c30041e78ea3f037b5778",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "PyQt6-sip"
                    }
                }
            ]
        },
        {
            "name": "pyqt-builder",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-build-isolation --verbose --prefix=${FLATPAK_DEST} ."
            ],
            "cleanup": [
                "*"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.pythonhosted.org/packages/e3/90/930091ec6bae121dd44ccaab0a59308e2b75870c6f76c23247caef68c8c8/pyqt_builder-1.16.1.tar.gz",
                    "sha256": "25fd79248ee29779ca2d83cfd5a35f6da962c6e9711b7434182d6ef30827cb49",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "pyqt-builder"
                    }
                }
            ]
        },
        {
            "name": "pyqt",
            "buildsystem": "simple",
            "build-commands": [
                ". ${FLATPAK_BUILDER_BUILDDIR}/build"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.pythonhosted.org/packages/8c/2b/6fe0409501798abc780a70cab48c39599742ab5a8168e682107eaab78fca/PyQt6-6.6.1.tar.gz",
                    "sha256": "9f158aa29d205142c56f0f35d07784b8df0be28378d20a97bcda8bd64ffd0379",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "PyQt6"
                    }
                },
                {
                    "type": "file",
                    "path": "pyqt-build",
                    "dest-filename": "build"
                },
                {
                    "type": "shell",
                    "commands": [
                        "echo '[tool.sip.bindings.QtGui]' >> pyproject.toml",
                        "echo 'disabled-features = [\"PyQt_Desktop_OpenGL\"]' >> pyproject.toml"
                    ],
                    "only-arches": [
                        "aarch64"
                    ]
                }
            ],
            "cleanup": [
                "/bin"
            ]
        },
        {
            "name": "chromaprint",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_BUILD_TYPE:STRING=Release",
                "-DBUILD_TOOLS:BOOL=ON"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/acoustid/chromaprint.git",
                    "commit": "aa67c95b9e486884a6d3ee8b0c91207d8c2b0551"
                }
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig"
            ]
        },
        {
            "name": "libdiscid",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/metabrainz/libdiscid/archive/v0.6.4.tar.gz",
                    "sha256": "c581baeabaf6e410398005645d66acaaa41ff2cab272c267a2d6839e41486ebb",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1592,
                        "stable-only": true,
                        "url-template": "https://github.com/metabrainz/libdiscid/archive/v$version.tar.gz"
                    }
                }
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig"
            ]
        },
        {
            "name": "rsgain",
            "buildsystem": "cmake-ninja",
            "build-options": {
                "ldflags": "-lpthread",
                "cxxflags": "-lpthread"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/complexlogic/rsgain/releases/download/v3.1/rsgain-3.1-source.tar.xz",
                    "sha256": "c1ab2c2162c1046786254090f939d60da87994efad5715dde68aa5247f33eaa3"
                }
            ],
            "modules": [
                {
                    "name": "libebur128",
                    "buildsystem": "cmake-ninja",
                    "cleanup": [
                        "/include",
                        "/lib/pkgconfig"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/jiixyj/libebur128/archive/refs/tags/v1.2.6.tar.gz",
                            "sha256": "baa7fc293a3d4651e244d8022ad03ab797ca3c2ad8442c43199afe8059faa613"
                        }
                    ]
                },
                {
                    "name": "inih",
                    "buildsystem": "meson",
                    "cleanup": [
                        "/include",
                        "/lib/pkgconfig"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/benhoyt/inih/archive/refs/tags/r56.zip",
                            "sha256": "22c9902ebe707a4d186b79abdf05ab1ab45e09b840c9fd9eb233244fbaabf3e8"
                        }
                    ]
                },
                {
                    "name": "fmt",
                    "buildsystem": "cmake-ninja",
                    "config-opts": [
                        "-DFMT_TEST=off",
                        "-DFMT_DOC=off"
                    ],
                    "cleanup": [
                        "*"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/fmtlib/fmt/releases/download/9.0.0/fmt-9.0.0.zip",
                            "sha256": "fc96dd2d2fdf2bded630787adba892c23cb9e35c6fd3273c136b0c57d4651ad6"
                        }
                    ]
                }
            ]
        },
        "files/python3-deps.json",
        {
            "name": "python3-aubio",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --verbose --prefix=${FLATPAK_DEST} --no-build-isolation ."
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.pythonhosted.org/packages/cd/80/302d89240603e5347c7f8026c8b02c59f8dfaec66c91a743d82de7c86006/aubio-0.4.9.tar.gz",
                    "sha256": "df1244f6c4cf5bea382c8c2d35aa43bc31f4cf631fe325ae3992c219546a4202",
                    "x-checker-data": {
                        "type": "pypi",
                        "name": "aubio"
                    }
                },
                {
                    "type": "patch",
                    "path": "patches/aubio/support-ffmpeg5.patch"
                }
            ],
            "cleanup": [
                "/bin",
                "/share/man/man1"
            ]
        },
        {
            "name": "picard",
            "buildsystem": "simple",
            "build-commands": [
                "python3 setup.py install --disable-autoupdate --prefix=${FLATPAK_DEST}"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Lctrs/picard.git",
                    "commit": "aac51806173527477b1c8432f1f8d9c42cddd50b",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^release-([\\d.]+)$",
                        "is-main-source": true
                    }
                }
            ]
        }
    ]
}
